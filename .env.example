# ═══════════════════════════════════════════════════════════════════════════
# K-DRAMA BOT - ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in your actual values
# Command: cp .env.example .env
#
# ═══════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────────
# TELEGRAM BOT CONFIGURATION
# ───────────────────────────────────────────────────────────────────────────
# Get these from BotFather: https://t.me/BotFather
# Command: /newbot

# Your Telegram API ID (numeric)
# Get from: https://my.telegram.org/apps
API_ID=123456789

# Your Telegram API Hash (alphanumeric string)
# Get from: https://my.telegram.org/apps
API_HASH=your_api_hash_here_abcdef1234567890

# Your Bot Token from BotFather
# Format: 123456789:ABCDefGhIjKLmnOPqRstuVWxyz_1234567890
BOT_TOKEN=your_bot_token_here


# ───────────────────────────────────────────────────────────────────────────
# ADMIN CONFIGURATION
# ───────────────────────────────────────────────────────────────────────────
# Set admin user IDs who can manage the bot

# Primary admin ID (your Telegram user ID)
# Get your ID: Send /start to @userinfobot
ADMIN_ID=987654321

# Secondary admin ID (optional)
SECONDARY_ADMIN_ID=0

# Additional admin IDs (comma-separated, optional)
# Example: 111111111,222222222,333333333
ADMIN_IDS=


# ───────────────────────────────────────────────────────────────────────────
# CHANNEL CONFIGURATION
# ───────────────────────────────────────────────────────────────────────────
# Required channels users must join before using the bot

# Storage channel ID (where bot stores photos/media)
# Format: -100123456789 (with -100 prefix for private channels)
# Create a private channel, add bot as admin, then use its ID
STORAGE_CHANNEL_ID=-100123456789

# Main channel link (for join button)
# Format: https://t.me/your_channel
MAIN_CHANNEL_LINK=https://t.me/your_channel

# Second channel link (optional)
SECOND_CHANNEL_LINK=https://t.me/your_second_channel

# Required channels (comma-separated)
# Users MUST be members of these channels to use the bot
# Format: @channel1,@channel2 or t.me/channel1,t.me/channel2
REQUIRED_CHANNELS=@Seoul_Entertainment_DKD


# ───────────────────────────────────────────────────────────────────────────
# DATABASE CONFIGURATION
# ───────────────────────────────────────────────────────────────────────────
# MongoDB connection details

# MongoDB URI (connection string)
# Local: mongodb://localhost:27017/
# MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
# Alternative: Use mongo_url instead of MONGO_URI
MONGO_URI=mongodb://localhost:27017/k_drama_bot

# Alternative MongoDB connection string (if MONGO_URI not set)
# mongo_url=mongodb://localhost:27017/k_drama_bot


# ───────────────────────────────────────────────────────────────────────────
# REDIS CONFIGURATION (Optional)
# ───────────────────────────────────────────────────────────────────────────
# Redis for caching (optional, used for performance optimization)

# Redis URL
# Local: redis://localhost:6379/0
# Remote: redis://username:password@host:port/0
REDIS_URL=redis://localhost:6379/0


# ═══════════════════════════════════════════════════════════════════════════
# SETUP INSTRUCTIONS
# ═══════════════════════════════════════════════════════════════════════════
#
# 1. GET TELEGRAM API CREDENTIALS
#    - Go to https://my.telegram.org/apps
#    - Log in with your Telegram account
#    - Create an app (if not already created)
#    - Copy API_ID and API_HASH
#
# 2. CREATE BOT AND GET TOKEN
#    - Message @BotFather on Telegram
#    - Use /newbot command
#    - Choose a name and username
#    - Copy the bot token
#
# 3. GET YOUR ADMIN ID
#    - Message @userinfobot on Telegram
#    - It will show your Telegram user ID
#
# 4. SETUP STORAGE CHANNEL
#    - Create a private Telegram channel
#    - Add your bot as an admin
#    - Message @rawdatabot in the channel to get the channel ID
#    - Use format: -100 + channel_id (e.g., -100123456789)
#
# 5. SETUP REQUIRED CHANNELS
#    - Create channels that users must join
#    - Add as comma-separated values in REQUIRED_CHANNELS
#
# 6. SETUP MONGODB
#    - Option A: Local MongoDB (install MongoDB locally)
#    - Option B: MongoDB Atlas (free cloud database)
#      - Go to https://www.mongodb.com/cloud/atlas
#      - Create free tier cluster
#      - Create database user
#      - Get connection string
#
# 7. SAVE THIS FILE
#    - Save as .env in the project root directory
#    - Keep .env secure (don't commit to git)
#
# ═══════════════════════════════════════════════════════════════════════════
